#!/usr/bin/env bash
# Lightweight launcher to run the built CLI from the project root.
# Allows running `./commit-helper ...` without installing the package globally.

# Resolve repo root (script directory)
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
NODE_BIN="$(command -v node)"

if [ -z "$NODE_BIN" ]; then
  echo "Node.js not found in PATH. Please install Node.js to use commit-helper." >&2
  exit 1
fi

exec "$NODE_BIN" "$SCRIPT_DIR/dist/cli.js" "$@"
