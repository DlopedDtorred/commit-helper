{
  "name": "commit-helper",
  "version": "1.0.1",
  "description": "A powerful CLI tool to help developers write conventional commits with ease",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "commit-helper": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "ts-node src/cli.ts",
    "test": "vitest",
    "start": "node dist/cli.js",
    "prepare": "npm run build",
    "postinstall": "chmod +x commit-helper || true"
  },
  "keywords": [
    "commit",
    "conventional-commits",
    "git",
    "cli",
    "changelog",
    "commitizen"
  ],
  "author": "DevTools Contributors",
  "license": "MIT",
  "preferGlobal": true,
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=18"
  },
  "homepage": "https://github.com/dlopeddtorred/commit-helper",
  "prepack": "npm run build",
  "repository": {
    "type": "git",
    "url": "https://github.com/dlopeddtorred/commit-helper"
  },
  "dependencies": {
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "inquirer": "^9.2.10",
    "ora": "^8.0.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/inquirer": "^9.0.7",
    "typescript": "^5.3.3",
    "ts-node": "^10.9.2",
    "vitest": "^1.0.0"
  }
}
